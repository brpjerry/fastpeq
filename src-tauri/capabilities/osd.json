{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "osd",
  "description": "Permissions for the OSD overlay window: receive osd:show events, hide itself, and set its position.",
  "windows": ["osd"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-ignore-cursor-events"
  ]
}
